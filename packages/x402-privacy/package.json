{
  "name": "@x402/privacy",
  "version": "0.1.0",
  "description": "Shielded payment scheme for x402 — private API payments via ZK-UTXO proofs",
  "type": "module",
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./client": {
      "types": "./dist/esm/client/index.d.ts",
      "import": "./dist/esm/client/index.js",
      "require": "./dist/cjs/client/index.cjs"
    },
    "./facilitator": {
      "types": "./dist/esm/facilitator/index.d.ts",
      "import": "./dist/esm/facilitator/index.js",
      "require": "./dist/cjs/facilitator/index.cjs"
    },
    "./server": {
      "types": "./dist/esm/server/index.d.ts",
      "import": "./dist/esm/server/index.js",
      "require": "./dist/cjs/server/index.cjs"
    },
    "./tree": {
      "types": "./dist/esm/tree/index.d.ts",
      "import": "./dist/esm/tree/index.js",
      "require": "./dist/cjs/tree/index.cjs"
    },
    "./crypto": {
      "types": "./dist/esm/crypto/index.d.ts",
      "import": "./dist/esm/crypto/index.js",
      "require": "./dist/cjs/crypto/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "circomlibjs": "^0.1.7",
    "express": "^4.21.0",
    "snarkjs": "^0.7.6",
    "viem": "^2.39.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "tsup": "^8.4.0",
    "typescript": "^5.7.3",
    "vitest": "^3.1.1"
  },
  "peerDependencies": {
    "@x402/core": ">=2.0.0"
  },
  "files": [
    "dist",
    "circuits"
  ],
  "license": "Apache-2.0",
  "author": "Dust Protocol",
  "repository": {
    "type": "git",
    "url": "https://github.com/dust-protocol/x402-privacy.git"
  },
  "homepage": "https://github.com/dust-protocol/x402-privacy#readme",
  "bugs": {
    "url": "https://github.com/dust-protocol/x402-privacy/issues"
  },
  "keywords": [
    "x402",
    "privacy",
    "zk",
    "zero-knowledge",
    "fflonk",
    "utxo",
    "dustpool",
    "payments",
    "ai-agents",
    "http-402"
  ],
  "engines": {
    "node": ">=18"
  }
}
