# Dust Protocol - Environment Variables
# Network: Polkadot Hub Testnet (chain ID: 420420417)

# Sponsor / Relayer Key
# Used by Next.js API routes for:
#   - Legacy sponsor-claim relay
#   - DustPool deposit/withdraw relay
#   - On-chain announcements + name registrations
RELAYER_PRIVATE_KEY=your_relayer_private_key_here

# Gelato 1Balance API key for gasless relay (server-side only)
GELATO_API_KEY=

# Relayer URL (defaults to http://localhost:3001 if not set)
NEXT_PUBLIC_RELAYER_URL=http://localhost:3001

# Polkadot Hub RPC endpoint
NEXT_PUBLIC_POLKADOT_HUB_RPC=https://eth-rpc-testnet.polkadot.io

# The Graph — Subgraph Query URL (optional)
# Deploy subgraph to Subgraph Studio, then paste query URL here.
# See docs/GRAPH_DEPLOYMENT.md for setup instructions.
# Format: https://api.studio.thegraph.com/query/<STUDIO_ID>/<SUBGRAPH_NAME>/version/latest
NEXT_PUBLIC_SUBGRAPH_URL_POLKADOT_HUB=

# Feature flag: use The Graph for name queries instead of RPC calls
# Set to 'true' after deploying subgraph and confirming sync is complete
NEXT_PUBLIC_USE_GRAPH=false

# V2 FFLONK proving key URL (optional)
# V2 zkeys — too large for git. Host on Cloudflare R2 or similar CDN.
# If not set, falls back to local public dir
NEXT_PUBLIC_V2_ZKEY_URL=
NEXT_PUBLIC_V2_SPLIT_ZKEY_URL=
